---
import { siteConfig } from "../data/site";
---

<div class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-3">
  <!-- Zalo button -->
  <a
    href={siteConfig.zaloUrl}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Zalo"
    class="group relative flex items-center justify-center w-14 h-14 rounded-full shadow-lg transition-all duration-300"
    style="background-color: #0068ff;"
  >
    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 relative z-10">
      <path d="M24 4C13 4 4 13 4 24C4 28.7 5.6 33 8.3 36.4L5 43L12 40C15.2 42.3 19.5 43.9 24 43.9C35 43.9 44 34.9 44 23.9C44 13 35 4 24 4Z" fill="white"/>
      <path d="M15 20H25M15 24H21M29 20V28L23 28" stroke="#0068ff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      <text x="12" y="29" font-size="11" font-weight="700" fill="#0068ff" font-family="Arial">Zalo</text>
    </svg>
    <!-- Tooltip -->
    <span class="absolute right-16 whitespace-nowrap bg-white text-[#0068ff] text-sm font-medium px-3 py-1.5 rounded-full shadow opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none">
      Zalo
    </span>
  </a>

  <!-- Facebook button -->
  <a
    href={siteConfig.facebookUrl}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Facebook"
    class="group relative flex items-center justify-center w-14 h-14 rounded-full shadow-lg transition-all duration-300"
    style="background-color: #1877f2;"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-7 h-7 relative z-10">
      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
    </svg>
    <!-- Tooltip -->
    <span class="absolute right-16 whitespace-nowrap bg-white text-[#1877f2] text-sm font-medium px-3 py-1.5 rounded-full shadow opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none">
      Facebook
    </span>
  </a>

  <!-- Phone button -->
  <a
    href={`tel:${siteConfig.phone}`}
    aria-label="Gọi điện"
    class="group relative flex items-center justify-center w-14 h-14 rounded-full shadow-lg bg-[--forest] hover:bg-[--forest-dark] transition-all duration-300"
  >
    <!-- Ripple rings -->
    <span class="absolute inset-0 rounded-full bg-[--forest] opacity-30 animate-ping"></span>
    <span class="absolute inset-0 rounded-full bg-[--forest] opacity-20 animate-ping [animation-delay:0.4s]"></span>
    <!-- Phone icon -->
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-white relative z-10">
      <path fill-rule="evenodd" d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z" clip-rule="evenodd" />
    </svg>
    <!-- Tooltip -->
    <span class="absolute right-16 whitespace-nowrap bg-white text-[--forest] text-sm font-medium px-3 py-1.5 rounded-full shadow opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none">
      {siteConfig.phoneDisplay}
    </span>
  </a>
</div>
