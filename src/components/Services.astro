---
import { services } from "../data/services";
---

<section id="services" class="py-12">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-2xl font-semibold">Dịch vụ tại CoNamSpa</h2>
    <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((s) => (
        <article class="bg-white p-4 rounded shadow-sm" key={s.title}>
          <img src={s.image} alt={s.title} class="w-full h-40 object-cover rounded" />
          <h3 class="mt-3 font-semibold">{s.title}</h3>
          <p class="text-sm text-stone-600 mt-1">{s.description}</p>
          <div class="mt-3 flex items-center justify-between">
            <div class="text-indigo-700 font-semibold">{s.price}</div>
            <a href="/" class="bg-indigo-700 hover:bg-indigo-800 text-white px-3 py-1 rounded">Đặt lịch</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
