---
import { siteConfig } from "../data/site";
---

<section id="hero" class="py-16">
  <div class="max-w-6xl mx-auto px-4 grid gap-8 md:grid-cols-2 items-center">
    <div>
      <h1 class="text-3xl md:text-4xl font-bold">{siteConfig.name} - Không gian chăm sóc sắc đẹp và thư giãn tại TP.HCM</h1>
      <p class="mt-4 text-stone-600">{siteConfig.slogan}</p>
      <div class="mt-6 flex gap-3">
         <a href={siteConfig.bookingUrl} class="bg-indigo-700 hover:bg-indigo-800 text-white px-4 py-2 rounded">Đặt lịch ngay</a>
         <a href="#services" class="bg-white border border-indigo-200 text-indigo-700 px-4 py-2 rounded hover:bg-indigo-50">Xem dịch vụ</a>
      </div>
    </div>
    <div>
      <img src={siteConfig.heroImage} alt="Không gian spa CoNamSpa" class="rounded shadow-lg" />
    </div>
  </div>
</section>
