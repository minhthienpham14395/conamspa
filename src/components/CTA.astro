---
import { siteConfig } from "../data/site";
---

<section id="cta" class="py-12 bg-indigo-50">
   <div class="max-w-6xl mx-auto px-4 text-center">
     <h2 class="text-2xl font-semibold text-indigo-900">Sẵn sàng trải nghiệm CoNamSpa?</h2>
     <p class="mt-2 text-stone-600">Đặt lịch nhanh qua EasySalon để chọn dịch vụ và khung giờ phù hợp.</p>
     <div class="mt-4">
       <a href={siteConfig.bookingUrl} class="bg-indigo-700 hover:bg-indigo-800 text-white px-6 py-3 rounded">Đặt lịch ngay</a>
    </div>
  </div>
</section>
