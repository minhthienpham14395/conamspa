---
import { siteConfig } from "../data/site";
---

<footer class="border-t mt-12">
  <div class="max-w-6xl mx-auto p-6 flex flex-col md:flex-row justify-between items-start gap-6">
    <div>
      <div class="text-lg font-bold">{siteConfig.name}</div>
      <div class="text-sm text-stone-600 mt-1">{siteConfig.description}</div>
    </div>
    <div class="text-sm">
      <div>{siteConfig.address}</div>
      <div class="mt-1">{siteConfig.phone}</div>
    </div>
  </div>
  <div class="text-center text-xs text-stone-500 p-4">© {new Date().getFullYear()} {siteConfig.name}. All rights reserved.</div>
</footer>
