    services: [
      {
        name: "Gội Thư Giãn",
        duration: "30 phút",
        price: "79.000đ",
        details: "Tẩy trang · Rửa mặt · Mát-xa đầu khô · Chườm túi thảo dược · Gội đầu 2 lần · Ủ xả tóc · Dưỡng tóc · Sấy tóc",
      },
      {
        name: "Gội Thư Giãn",
        duration: "40 phút",
