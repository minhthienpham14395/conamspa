        details: "Ngâm chân · Mát-xa toàn thân mặt úp: thắt lưng, cổ vai gáy, tay, chân và đá nóng lưng · Mát-xa mặt ngửa: tay, chân, đầu, mặt · Chườm nóng thảo dược · Lau khăn ấm",
      },
      {
        name: "Mát-Xa Thư Giãn Toàn Thân",
        duration: "90 phút",
        price: "450.000đ",
        details: "Liệu trình toàn thân kéo dài, chăm sóc kỹ vùng lưng, cổ vai gáy, tay, chân, đầu và mặt; kết hợp đá nóng và thảo dược.",
      },
      {
        name: "Mát-Xa Toàn Thân Đá Nóng",
        duration: "90 phút",
        price: "480.000đ",
        details: "Ngâm chân · Mát-xa toàn thân mặt úp và đá nóng toàn vùng · Mát-xa mặt ngửa: tay, chân, đầu, mặt · Chườm nóng thảo dược · Lau khăn ấm",
      },
      {
        name: "Mát-Xa Trị Liệu Cổ Vai Gáy",
        duration: "80 phút",
        price: "550.000đ",
        details: "Ngâm chân · Làm nóng dọc mạch bằng rượu thuốc · Khai huyệt · Trị liệu truy vết điểm đau tắt nghẽn thắt lưng, cổ vai gáy · Đá nóng · Chườm thảo dược · Mát-xa tay, đầu · Lau khăn nóng",
      },
      {
        name: "Mát-Xa Trị Liệu Toàn Thân",
        duration: "90 phút",
        price: "650.000đ",
        details: "Ngâm chân · Làm nóng dọc mạch bằng rượu thuốc · Khai huyệt · Trị liệu truy vết điểm đau toàn thân · Mát-xa tay, chân · Đá nóng · Đắp thuốc và chườm nóng thảo dược · Mát-xa đầu · Lau khăn nóng",
      },
    ],
    extras: [
      "Trượt giác & giác hơi 20 phút — 150.000đ",
      "Đắp thuốc thảo dược — 100.000đ",
    ],
  },
  {
    id: "combo",
    eyebrow: "Gói tiết kiệm",
    title: "Dịch Vụ Combo",
    description: "Kết hợp nhiều liệu trình trong một buổi để thư giãn trọn vẹn với mức giá ưu đãi hơn.",
    services: [
      {
        name: "Gội Chuyên Sâu & Mát-Xa Tay Chân",
        duration: "90 phút",
        price: "329.000đ",
        details: "Gội đầu chuyên sâu 60 phút kết hợp mát-xa thư giãn tay chân 30 phút.",
      },
      {
        name: "Gội Chuyên Sâu & Mát-Xa Cổ Vai Gáy",
        duration: "90 phút",
        price: "329.000đ",
        details: "Gội đầu chuyên sâu 60 phút kết hợp mát-xa thư giãn cổ vai gáy, lưng úp 30 phút.",
      },
      {
        name: "Mát-Xa Cổ Vai Gáy & Gội Đầu",
        duration: "90 phút",
        price: "359.000đ",
        details: "Mát-xa thư giãn cổ vai gáy 60 phút kết hợp các bước của gói gội đầu thư giãn 30 phút.",
      },
      {
        name: "Mát-Xa Toàn Thân & Gội Đầu",
