---

<MainLayout>
  <header class="site-header hero-mode" id="site-header">
    <div class="header-inner">
       <a href="/" class="site-logo" aria-label="Cô Năm Spa - Trang chủ">
        <img src="/images/logo.jpg" alt="Cô Năm - Tiệm Gội Đầu Thư Giãn" />
      </a>
      <nav class="main-nav" id="main-nav" aria-label="Điều hướng chính">
        <ul class="nav-menu">
          <li><a href="#sanctuary">Không Gian</a></li>
          <li><a href="#services">Dịch Vụ</a></li>
          <li><a href="#rituals">Liệu Trình</a></li>
          <li><a href="#contact">Liên Hệ</a></li>
        </ul>
        <a href={siteConfig.bookingUrl} class="btn btn-primary nav-cta">Đặt Lịch Trị Liệu</a>
      </nav>
      <button class="mobile-menu-toggle" id="mobile-toggle" aria-expanded="false" aria-controls="main-nav" aria-label="Mở menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <main>
    <section class="hero-section" id="sanctuary" aria-label="Cô Năm Spa">
      <div class="hero-bg">
        <img
          src="/images/hero/727457690_1059334386607528_499987599721631516_n.jpg"
          alt="Không gian thực tế tại Cô Năm Spa"
          fetchpriority="high"
        />
      </div>
      <div class="hero-content container">
        <div class="hero-badge"><span>🌿</span><span>Chốn Bình Yên Cho Mọi Giác Quan · Thành Phố Hồ Chí Minh</span></div>
        <h1 class="hero-title">Nơi Tâm Hồn Giao Thoa Cùng <em>Thiên Nhiên</em></h1>
        <p class="hero-desc">Trải nghiệm liệu pháp chữa lành từ thiên nhiên, được chắt lọc qua hàng nghìn năm trí tuệ.</p>
        <div class="hero-actions">
          <a href={siteConfig.bookingUrl} class="btn btn-primary">Đặt Lịch Ngay</a>
          <a href="#services" class="btn btn-ghost">Khám Phá Dịch Vụ</a>
        </div>
      </div>
      <a class="hero-scroll" href="#services" aria-label="Khám phá dịch vụ"><span>Khám Phá</span></a>
    </section>

    <section class="treatments-section" id="services">
      <div class="container">
        <header class="treatments-header fade-in">
          <span class="section-label">Bảng Giá Cô Năm Spa</span>
          <h2 class="section-title">Dịch Vụ Chăm Sóc & Thư Giãn</h2>
          <p class="section-desc">Chọn liệu trình phù hợp với thời gian và nhu cầu của bạn.</p>
        </header>
        <nav class="service-tabs" aria-label="Danh mục dịch vụ">
          {serviceGroups.map((group, index) => (
            <button
              type="button"
              class:list={["service-tab", { active: index === 0 }]}
              data-service-tab={group.id}
              aria-controls={group.id}
              aria-selected={index === 0 ? "true" : "false"}
            >
              {group.title}
            </button>
          ))}
        </nav>
        <div class="service-catalog" id="service-slider">
          {serviceGroups.map((group) => (
            <section class="service-group" id={group.id} data-service-panel={group.id}>
              <header class="service-group-header">
                <div>
                  <span class="section-label">{group.eyebrow}</span>
                  <h3>{group.title}</h3>
                </div>
                <p>{group.description}</p>
              </header>
              <div class="service-list">
                {group.services.map((service) => (
                  <article class="service-item">
                    <div class="service-item-top">
                      <div>
                        <h4>{service.name}</h4>
                        <span class="service-duration">{service.duration}</span>
                      </div>
                      <strong>{service.price}</strong>
                    </div>
                    <p>{service.details}</p>
                    <a href={siteConfig.bookingUrl} class="service-booking">Đặt lịch <span aria-hidden="true">→</span></a>
                  </article>
                ))}
              </div>
              {group.extras.length > 0 && (
                <div class="service-extras">
                  <h4>Dịch Vụ Thêm</h4>
                  <ul>{group.extras.map((extra) => <li>{extra}</li>)}</ul>
                </div>
              )}
            </section>
          ))}
        </div>
        <div class="service-note">
          <p>Thời lượng và quy trình có thể được điều chỉnh theo tình trạng thực tế. Vui lòng đặt lịch trước để được phục vụ tốt nhất.</p>
          <a href={siteConfig.bookingUrl} class="btn btn-primary">Đặt Lịch Ngay</a>
        </div>
      </div>
    </section>

    <section class="promotions-section" id="uu-dai">
      <div class="container">
        <header class="promotions-header fade-in">
          <span class="section-label">Chương Trình Đặc Biệt</span>
          <h2 class="section-title">Ưu Đãi Tại Cô Năm Spa</h2>
          <p class="section-desc">Khám phá các liệu trình đang có mức giá ưu đãi và đặt lịch để giữ khung giờ phù hợp.</p>
        </header>
        <div class="promotions-grid">
          {promotionImages.map((promotion) => (
            <a
              href={siteConfig.bookingUrl}
              class="promotion-card fade-in"
              aria-label={`${promotion.alt} - Đặt lịch ngay`}
            >
              <img src={promotion.src} alt={promotion.alt} loading="lazy" />
              <span>Đặt Lịch Ngay</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="about-section" id="rituals">
      <div class="container">
        <div class="about-inner">
          <div class="about-visual fade-in">
            <div class="about-video-main">
              <video
                autoplay
                controls
                muted
                loop
                playsinline
                preload="metadata"
                poster="/images/about-main.jpg"
                aria-label="Video giới thiệu không gian và dịch vụ Cô Năm Spa"
              >
                <source src="/videos/1782148547003_7280312537000100950_7280312537000100950.mp4" type="video/mp4" />
                Trình duyệt của bạn không hỗ trợ phát video.
              </video>
            </div>
            <!-- <div class="about-image-accent"><img src="/images/about-accent.jpg" alt="Sản phẩm tự nhiên" loading="lazy" /></div> -->
          </div>
          <div class="about-content fade-in">
            <span class="about-tagline">Câu chuyện của chúng tôi</span>
            <h2>Thấu Hiểu Tiếng Nói Từ Thiên Nhiên</h2>
            <p>Tại Cô Năm Spa, chúng tôi tin rằng vẻ đẹp bền vững bắt nguồn từ sự hòa hợp với đất mẹ. Mỗi thành phần được sử dụng đều là thảo mộc hữu cơ, được tuyển chọn kỹ lưỡng từ những khu vườn bền vững.</p>
            <p>Chúng tôi từ chối các hoạt chất mạnh, ưu tiên các liệu pháp đánh thức giác quan và nuôi dưỡng da bằng dưỡng chất một cách thuần khiết nhất.</p>
            <div class="about-stats">
              <div><div class="stat-number">98%</div><div class="stat-label">Hữu Cơ Thuần Khiết</div></div>
              <div><div class="stat-number">8+</div><div class="stat-label">Năm Kinh Nghiệm</div></div>
            </div>
            <a href="https://conamspa.io.vn/ve-chung-toi" class="btn btn-secondary about-button">Tìm Hiểu Thêm</a>
          </div>
        </div>
      </div>
    </section>

    <section class="testimonials-section" aria-label="Cảm nhận khách hàng">
      <div class="container">
        <header class="testimonials-header fade-in">
          <span class="section-label">Cảm Nhận</span>
          <h2 class="section-title">Cảm Nhận Từ Trái Tim</h2>
        </header>
        <div class="testimonials-slider">
          {testimonials.map((item, index) => (
            <article class:list={["testimonial-item", { active: index === 0 }]} data-slide={index}>
              <span class="quote-mark" aria-hidden="true">99</span>
              <blockquote><p class="testimonial-text">“{item.text}”</p></blockquote>
              <div class="testimonial-author">
                <div class="author-avatar-placeholder">{item.initial}</div>
                <div class="author-info"><div class="author-name">{item.name}</div><div class="author-role">{item.role}</div></div>
              </div>
            </article>
          ))}
        </div>
        <div class="testimonial-dots" role="tablist">
          {testimonials.map((_, index) => <button class:list={["dot", { active: index === 0 }]} data-index={index} aria-label={`Cảm nhận ${index + 1}`}></button>)}
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="cta-bg"><img src="/images/cta-bg.jpg" alt="" loading="lazy" /></div>
      <div class="cta-content">
        <h2>Sẵn Sàng Cho Hành Trình Chữa Lành?</h2>
        <p>Đặt lịch hẹn ngay hôm nay để được tư vấn miễn phí và chọn lựa giải pháp chăm sóc sức khoẻ tốt nhất cho bạn.</p>
        <a href={siteConfig.bookingUrl} class="btn btn-ghost">Đặt Lịch Hẹn Ngay</a>
      </div>
    </section>
  </main>

  <footer class="site-footer" id="contact">
    <div class="container">
      <div class="footer-inner">
        <div class="footer-brand">
          <a href="/" class="footer-logo" aria-label="Cô Năm Spa - Trang chủ">
            <img src="/images/logo.jpg" alt="Cô Năm - Tiệm Gội Đầu Thư Giãn" loading="lazy" />
          </a>
          <p>Không gian chăm sóc và chữa lành từ thiên nhiên.</p>
          <div class="footer-social">
            <a href={`mailto:${siteConfig.email}`} class="social-link" aria-label="Gửi Gmail cho Cô Năm Spa">✉</a>
            <a href={siteConfig.facebookUrl} class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Facebook Cô Năm Spa">f</a>
          </div>
        </div>
        <div class="footer-col">
          <h4>Dịch Vụ</h4>
          <ul>
            <li><a href={siteConfig.servicesUrl}>Mát-xa Trị Liệu</a></li>
            <li><a href={siteConfig.servicesUrl}>Chăm Sóc Da Mặt</a></li>
            <li><a href="#rituals">Liệu Trình Toàn Thân</a></li>
            <li><a href={siteConfig.servicesUrl}>Gói Dịch Vụ Đặc Biệt</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Về Chúng Tôi</h4>
          <ul>
            <li><a href="#">Phát Triển Bền Vững</a></li>
            <li><a href="#">Nghề Nghiệp</a></li>
            <li><a href="#">Chính Sách Bảo Mật</a></li>
            <li><a href="#">Điều Khoản Dịch Vụ</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Liên Hệ</h4>
          <div class="footer-contact-item">
            <span>📍</span>
            <a href={siteConfig.googleMapUrl} target="_blank" rel="noopener noreferrer" aria-label="Xem địa chỉ Cô Năm Spa trên Google Maps">
              {siteConfig.address}
            </a>
          </div>
          <div class="footer-contact-item"><span>📞</span><a href={`tel:${siteConfig.phone}`}>{siteConfig.phoneDisplay}</a></div>
          <div class="footer-contact-item">
            <span>💬</span>
            <a href={siteConfig.zaloUrl} target="_blank" rel="noopener noreferrer">Nhắn tin qua Zalo</a>
          </div>
          <div class="footer-contact-item"><span>✉</span><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></div>
          <div class="footer-contact-item">
            <span>ⓕ</span>
            <a href={siteConfig.facebookUrl} target="_blank" rel="noopener noreferrer">facebook.com/conamspa</a>
          </div>
