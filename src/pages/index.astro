      "Dầu gội nhập TIGI / Nexxus / Collagen — 40.000đ",
      "Dầu gội thảo dược — 10.000đ",
    ],
  },
  {
    id: "mat-xa",
    eyebrow: "Thư giãn & trị liệu",
    title: "Dịch Vụ Mát-Xa",
    description: "Liệu trình thư giãn và trị liệu được thiết kế theo từng vùng cơ thể và nhu cầu phục hồi.",
    services: [
      {
        name: "Mát-Xa Thư Giãn Cổ Vai Gáy",
