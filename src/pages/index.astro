        price: "429.000đ",
        details: "Mát-xa cổ vai gáy 60 phút kết hợp trị liệu cổ vai gáy 20 phút: làm nóng dọc mạch và đẩy hàn khí.",
      },
      {
        name: "Mát-Xa Toàn Thân Kết Hợp Trị Liệu",
        duration: "90 phút",
        price: "499.000đ",
