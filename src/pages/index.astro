---
import MainLayout from "../layouts/MainLayout.astro";
import { siteConfig } from "../data/site";
import { readdirSync } from "node:fs";
import { join } from "node:path";

const promotionDirectory = join(process.cwd(), "public", "images", "uudai");
const promotionImages = readdirSync(promotionDirectory)
  .filter((file) => /\.(avif|jpe?g|png|webp)$/i.test(file))
  .sort()
  .map((file, index) => ({
    src: `/images/uudai/${file}`,
    alt: `Ưu đãi dịch vụ Cô Năm Spa ${index + 1}`,
  }));

const testimonials = [
  {
    text: "Một không gian tuyệt vời để trốn khỏi sự ồn ào của phố thị. Liệu trình chăm sóc da mặt với trà xanh thực sự đã giúp làn da tôi hồi sinh. Đội ngũ nhân viên vô cùng tận tâm và chuyên nghiệp.",
    initial: "K",
    name: "Khánh Linh",
    role: "Nghệ sĩ tự do",
  },
  {
    text: "Liệu trình mát-xa đá muối Himalaya thực sự là một trải nghiệm độc đáo. Cảm giác thư giãn sâu mà không nơi nào có được. Tôi sẽ quay lại.",
    initial: "M",
    name: "Minh Châu",
    role: "Giám đốc tiếp thị",
  },
  {
    text: "Không gian đẹp, yên tĩnh, sản phẩm thuần thiên nhiên. Sau mỗi buổi chăm sóc, da tôi thực sự khỏe và sáng hơn rõ rệt.",
    initial: "T",
    name: "Thu Trang",
    role: "Bác sĩ",
  },
];

